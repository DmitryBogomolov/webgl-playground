{
  "name": "webgl-playground",
  "version": "0.0.1",
  "description": "WebGL playground",
  "private": true,
  "scripts": {
    "tscheck": "tsc -p tsconfig.json --noEmit",
    "dev": "NODE_OPTIONS='--require ts-node/register --no-experimental-strip-types' TS_NODE_PROJECT=./tsconfig.json webpack serve",
    "build": "NODE_OPTIONS='--require ts-node/register --no-experimental-strip-types' TS_NODE_PROJECT=./tsconfig.json webpack build",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest --workerThreads --detectOpenHandles",
    "bench:objects-create-access": "node ./benchmark/objects-create-access",
    "bench:vec3-operations": "node ./benchmark/vec3-operations"
  },
  "keywords": [
    "webgl"
  ],
  "author": "Dmitry Bogomolov",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/mustache": "4.2.6",
    "@types/node": "25.5.0",
    "css-loader": "7.1.4",
    "eslint": "10.2.0",
    "express": "5.2.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "mini-css-extract-plugin": "2.10.1",
    "mustache": "4.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.3"
  }
}
